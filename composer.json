{
    "name": "dave-liddament/test-mapper",
    "description": "Test Mapper",
    "type": "library",
    "license": "proprietary",
    "bin": ["bin/test-mapper", "bin/spec-reviewer"],
    "require": {
        "php": "8.3.*|8.4.*|8.5.*",
        "symfony/console": "^7.2",
        "symfony/process": "^7.2",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "*",
        "phpstan/phpstan": "*",
        "phpstan/phpstan-strict-rules": "*",
        "phpstan/phpstan-phpunit": "*",
        "phpstan/phpstan-webmozart-assert": "*",
        "dave-liddament/phpstan-php-language-extensions": "*",
        "spaze/phpstan-disallowed-calls": "*",
        "rector/rector": "*",
        "phpunit/phpunit": "*",
        "infection/infection": "^0.32.6",
        "dave-liddament/phpstan-rule-test-helper": "^0.6.0"
    },
    "autoload": {
        "psr-4": {
            "DaveLiddament\\TestMapper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DaveLiddament\\TestMapper\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "@composer install",
            "@composer bin all install"
        ],
        "ci": [
            "@composer-validate",
            "@lint",
            "@composer-unused",
            "@composer-require-checker",
            "@cs",
            "@phpstan",
            "@test",
            "@coverage"
        ],
        "ci-local": [
            "@composer-validate",
            "@lint",
            "@composer-unused",
            "@composer-require-checker",
            "@cs-fix",
            "@phpstan",
            "@test",
            "@coverage",
            "echo '\\n⚠ Infection (mutation testing) skipped in ci-local as it is slow. Run manually with: composer infection'"
        ],
        "composer-validate": "@composer validate --no-check-all --strict",
        "lint": "parallel-lint src tests bin",
        "composer-unused": "composer-unused",
        "composer-require-checker": "composer-require-checker check",
        "cs": "php-cs-fixer fix -v --dry-run",
        "cs-fix": "php-cs-fixer fix -v",
        "phpstan": "phpstan analyse --no-progress --memory-limit=-1",
        "test": "phpunit",
        "coverage": [
            "XDEBUG_MODE=coverage phpunit --coverage-clover build/coverage/clover.xml",
            "php bin/check-coverage build/coverage/clover.xml 100"
        ],
        "infection": "infection --show-mutations"
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true,
            "infection/extension-installer": true
        },
        "platform": {
            "php": "8.3.0"
        }
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "forward-command": true
        }
    }
}
